# Environment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Set this in deployed environments if you want social metadata to resolve to a
# stable protected URL. When omitted on Vercel, the app falls back to VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch
AGENT_NAME=clawdbot-agent

# Optional local cue while the agent is in the LiveKit "thinking" state.
# Presets: off, soft-pulse, glass
# In local development the frontend defaults to soft-pulse for testing unless you override it.
THINKING_SOUND_PRESET=soft-pulse
THINKING_SOUND_VOLUME=0.18
# Set to 0 to play only once when the agent enters thinking.
THINKING_SOUND_INTERVAL_MS=1800

# Optional app-level access gate for hosted deployments.
# Use a long random secret, not a short numeric PIN.
# When set, visitors must unlock the app before the page or /api/token can be used.
REPOLINE_ACCESS_PIN=

# Optional comma-separated hostnames to reject entirely.
# Example: repoline-frontend.vercel.app
REPOLINE_BLOCKED_HOSTS=

# Internal sandbox configuration
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
