LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=clawdbot-agent

BRIDGE_CLI_PROVIDER=claude
BRIDGE_WORKDIR=
BRIDGE_MODEL=
BRIDGE_THINKING_LEVEL=low
# readonly = inspect only, workspace-write = sandboxed project edits, owner = highest-permission local mode
BRIDGE_ACCESS_POLICY=readonly
# RepoLine loads this skill from the selected repo by default.
REPOLINE_SKILL_NAME=repoline-voice-session
# RepoLine also loads this mutable local skill for provider-specific pronunciation fixes.
REPOLINE_TTS_PRONUNCIATION_SKILL_NAME=repoline-tts-pronunciation
# Optional explicit override. Leave empty to require the installed RepoLine skill.
BRIDGE_SYSTEM_PROMPT=
BRIDGE_CHUNK_CHARS=140
FINAL_TRANSCRIPT_DEBOUNCE_SECONDS=0.85
BRIDGE_STATUS_SPEECH_ENABLED=true
BRIDGE_STATUS_SPEECH_DELAY_SECONDS=0.15
BRIDGE_STATUS_FOLLOWUP_DELAY_SECONDS=4.0
BRIDGE_STATUS_FOLLOWUP_INTERVAL_SECONDS=8.0
BRIDGE_TELEMETRY_JSONL=./logs/bridge-telemetry.jsonl

LIVEKIT_STT_MODEL=deepgram/nova-3
LIVEKIT_STT_LANGUAGE=multi
LIVEKIT_TTS_MODEL=cartesia/sonic-3
LIVEKIT_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
LIVEKIT_RECORD_AUDIO=true
LIVEKIT_RECORD_TRACES=true
LIVEKIT_RECORD_LOGS=true
LIVEKIT_RECORD_TRANSCRIPT=true
BRIDGE_PROMETHEUS_PORT=

BRIDGE_GREETING=RepoLine is live. What do you want to work on?
