{
  "name": "repoline",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "scripts": {
    "bootstrap": "bash ./scripts/bootstrap.sh",
    "setup": "bun run ./scripts/phone-bridge.ts setup",
    "dev": "bun run ./scripts/phone-bridge.ts dev",
    "live": "bun run ./scripts/phone-bridge.ts live",
    "agent": "bun run ./scripts/phone-bridge.ts agent",
    "doctor": "bun run ./scripts/phone-bridge.ts doctor",
    "benchmark:latency": "uv run --project agent python ./scripts/latency_harness.py",
    "benchmark:report": "uv run --project agent python ./scripts/latency_report.py",
    "benchmark:analyze": "uv run --project agent python ./scripts/latency_analysis.py"
  }
}
