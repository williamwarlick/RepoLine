{
  "defaults": {
    "working_directory": ".",
    "access_policy": "readonly",
    "chunk_chars": 100,
    "use_repoline_prompt": true,
    "thinking_level": "low",
    "repeats": 2,
    "timeout_seconds": 90,
    "report_group": "model-matrix-extended"
  },
  "scenarios": [
    {
      "name": "cursor-app-bridge-summary",
      "kind": "provider_stream",
      "provider": "cursor",
      "provider_transport": "app",
      "provider_submit_mode": "bridge-composer-handle",
      "model": "composer-2-fast",
      "task": "repo-summary",
      "variant": "Cursor App Bridge Handle",
      "prompt": "What does RepoLine do in one short sentence?"
    },
    {
      "name": "cursor-app-bridge-harness-path",
      "kind": "provider_stream",
      "provider": "cursor",
      "provider_transport": "app",
      "provider_submit_mode": "bridge-composer-handle",
      "model": "composer-2-fast",
      "task": "harness-path",
      "variant": "Cursor App Bridge Handle",
      "prompt": "Reply with just the path to the RepoLine Python latency harness wrapper script.",
      "expected_exact": "scripts/latency_harness.py"
    },
    {
      "name": "cursor-app-active-input-summary",
      "kind": "provider_stream",
      "provider": "cursor",
      "provider_transport": "app",
      "provider_submit_mode": "active-input",
      "model": "composer-2-fast",
      "task": "repo-summary",
      "variant": "Cursor App Active Input",
      "prompt": "What does RepoLine do in one short sentence?"
    },
    {
      "name": "cursor-app-active-input-harness-path",
      "kind": "provider_stream",
      "provider": "cursor",
      "provider_transport": "app",
      "provider_submit_mode": "active-input",
      "model": "composer-2-fast",
      "task": "harness-path",
      "variant": "Cursor App Active Input",
      "prompt": "Reply with just the path to the RepoLine Python latency harness wrapper script.",
      "expected_exact": "scripts/latency_harness.py"
    },
    {
      "name": "gemini-api-25-summary",
      "kind": "provider_stream",
      "provider": "gemini",
      "provider_transport": "api",
      "model": "gemini-2.5-flash",
      "task": "repo-summary",
      "variant": "Gemini API 2.5 Flash",
      "prompt": "What does RepoLine do in one short sentence?"
    },
    {
      "name": "gemini-api-25-harness-path",
      "kind": "provider_stream",
      "provider": "gemini",
      "provider_transport": "api",
      "model": "gemini-2.5-flash",
      "task": "harness-path",
      "variant": "Gemini API 2.5 Flash",
      "prompt": "Reply with just the path to the RepoLine Python latency harness wrapper script.",
      "expected_exact": "scripts/latency_harness.py"
    },
    {
      "name": "gemini-api-25-default-gemini-model",
      "kind": "provider_stream",
      "provider": "gemini",
      "provider_transport": "api",
      "model": "gemini-2.5-flash",
      "task": "default-gemini-model",
      "variant": "Gemini API 2.5 Flash",
      "prompt": "Reply with just the default Gemini model configured in this repo.",
      "expected_exact": "gemini-2.5-flash"
    }
  ]
}
